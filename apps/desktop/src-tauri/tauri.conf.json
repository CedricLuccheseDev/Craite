{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "CrAIte",
  "version": "0.4.5",
  "identifier": "dev.clhub.craite",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CrAIte",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "scope": {
          "allow": ["$HOME/**", "/mnt/**", "$APPDATA/**", "$LOCALAPPDATA/**"],
          "deny": []
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCOUM0NjIxQTI1QTU1MTAKUldRUVZWcWlJVWFjaTVzM1pIamx2cHB4NWJKUFFOZHIyNzJOcEZsVGZmTzdtOFg3M0E1b0J4MWQK",
      "endpoints": ["https://craite.app/api/update"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}

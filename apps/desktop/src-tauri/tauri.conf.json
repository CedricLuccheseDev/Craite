{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "CrAIte",
  "version": "0.4.6",
  "identifier": "dev.clhub.craite",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CrAIte",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; font-src 'self'; connect-src 'self' https://dl.craite.clhub.fr; media-src 'self' asset: https://asset.localhost blob:",
      "assetProtocol": {
        "scope": {
          "allow": [
            "$HOME/Music/**",
            "$HOME/Documents/**",
            "$HOME/Desktop/**",
            "$HOME/Downloads/**",
            "$HOME/.local/share/craite/**",
            "/mnt/*/Users/*/Music/**",
            "/mnt/*/Users/*/Documents/**",
            "/mnt/*/Users/*/Desktop/**",
            "/mnt/*/Users/*/Downloads/**",
            "$APPDATA/craite/**",
            "$LOCALAPPDATA/craite/**"
          ],
          "deny": ["$HOME/.ssh/**", "$HOME/.gnupg/**", "$HOME/.config/**"]
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCOUM0NjIxQTI1QTU1MTAKUldRUVZWcWlJVWFjaTVzM1pIamx2cHB4NWJKUFFOZHIyNzJOcEZsVGZmTzdtOFg3M0E1b0J4MWQK",
      "endpoints": ["https://dl.craite.clhub.fr/update.json"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}

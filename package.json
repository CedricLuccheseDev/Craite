{
  "name": "craite",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @app/desktop tauri dev",
    "dev:landing": "pnpm --filter @app/landing dev",
    "build": "pnpm --filter @app/desktop tauri build",
    "build:landing": "pnpm --filter @app/landing build",
    "lint": "eslint apps/",
    "lint:fix": "eslint apps/ --fix",
    "format": "prettier --write \"apps/**/*.{ts,tsx,vue,js,json,css,md}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,vue,js,json,css,md}\"",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "pnpm --filter @app/desktop exec vue-tsc --noEmit && pnpm --filter @app/landing exec nuxi typecheck",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "simple-git-hooks": "^2.12.0",
    "typescript-eslint": "^8.56.0",
    "vitest": "^2.1.8"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "pnpm test --run && cargo clippy --manifest-path apps/desktop/src-tauri/Cargo.toml -- -D warnings"
  },
  "pnpm": {
    "overrides": {
      "reka-ui": "^2.9.2",
      "unplugin": "^2.3.2"
    }
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx,vue,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/**/*.{json,css,md}": [
      "prettier --write"
    ],
    "apps/desktop/src-tauri/src/**/*.rs": [
      "cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml --"
    ]
  }
}

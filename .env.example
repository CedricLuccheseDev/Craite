# PostHog — Product analytics (same project for landing + desktop)
# Create a free account at https://posthog.com
# Find your key in Settings > Project > Project API Key
POSTHOG_KEY=phc_your_project_api_key_here
POSTHOG_HOST=https://us.i.posthog.com

# Vite requires VITE_ prefix to expose env vars to the desktop frontend
VITE_POSTHOG_KEY=phc_your_project_api_key_here
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Release distribution (landing page download links)
RELEASE_URL=https://dl.craite.clhub.fr
